# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-here-change-in-production

# Database (PostgreSQL en Neon.tech)
DATABASE_URL=postgresql://user:password@host/database_name

# Demo Mode (set to 'true' para modo demostración sin login)
DEMO_MODE=false

# Email Configuration (opcional)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=

# Logging
LOG_TO_STDOUT=true
